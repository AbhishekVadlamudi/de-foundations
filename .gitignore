# ============================================================
# Spark / Delta / lakehouse local artifacts
# ============================================================
# Spark writes a warehouse dir for local metastore
spark-warehouse/
metastore_db/
derby.log

# Local Delta tables generated during exploration
*.delta/
delta-table/

# Spark event logs (UI history)
spark-events/

# Hadoop / Hive
.hive/

# ============================================================
# Data — never commit data files
# ============================================================
data/raw/*
data/processed/*
# But keep the directories themselves
!data/raw/.gitkeep
!data/processed/.gitkeep

# Common data file extensions (defence in depth)
*.csv
*.parquet
*.json
*.jsonl
*.avro
*.orc
*.tsv
*.xlsx
*.xls

# ============================================================
# Secrets — defence in depth
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*_secret.*
*credentials*
*.tfvars
!*.tfvars.example

# ============================================================
# OS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

